{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tutorial-spec.schema.json",
  "title": "TutorialSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "description",
    "audience",
    "prerequisites",
    "learningObjectives",
    "scope",
    "lessons",
    "references",
    "concepts",
    "misconceptions",
    "workedExamples",
    "exercises",
    "answers",
    "formativeAssessment",
    "masteryCriteria",
    "recap",
    "nextSteps",
    "accessibility",
    "localization"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "audience": {
      "type": "object",
      "required": ["primary", "priorKnowledge"],
      "properties": {
        "primary": { "type": "string", "minLength": 1 },
        "priorKnowledge": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "roles": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "readingLevel": { "type": "string" }
      }
    },
    "prerequisites": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "learningObjectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "bloomLevel", "assessmentIds"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "bloomLevel": { "enum": ["remember", "understand", "apply", "analyze", "evaluate", "create"] },
          "assessmentIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "scope": {
      "type": "object",
      "required": ["inScope", "nonGoals"],
      "properties": {
        "inScope": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "nonGoals": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "lessons": { "type": "array", "minItems": 1 },
    "references": { "type": "array", "minItems": 1 },
    "concepts": { "type": "array", "minItems": 1 },
    "misconceptions": { "type": "array" },
    "workedExamples": { "type": "array" },
    "exercises": { "type": "array" },
    "answers": { "type": "array" },
    "formativeAssessment": { "type": "array", "minItems": 1 },
    "masteryCriteria": { "type": "array", "minItems": 1 },
    "recap": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "nextSteps": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "accessibility": { "type": "object" },
    "localization": { "type": "object" }
  }
}
